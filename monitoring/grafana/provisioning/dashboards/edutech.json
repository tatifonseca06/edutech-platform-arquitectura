{
  "title": "EduTech Platform — Overview",
  "uid": "edutech-overview",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["edutech", "microservices"],
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requests/seg — Cursos API",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"cursos-api\"}[1m]))",
        "legendFormat": "req/s"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 50}, {"color": "red", "value": 100}] },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Requests/seg — Notificaciones",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(rate(http_requests_total{job=\"notificaciones\"}[1m]))",
        "legendFormat": "req/s"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 50}] },
          "unit": "reqps"
        }
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Errores 5xx (último 5 min)",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "sum(increase(http_requests_total{status_code=~\"5..\"}[5m]))",
        "legendFormat": "errores"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "red", "value": 1}] }
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "CPU Usage",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [{
        "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{"color": "green", "value": 0}, {"color": "yellow", "value": 70}, {"color": "red", "value": 90}] }
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Latencia HTTP p99 (ms)",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"cursos-api\"}[1m])) by (le)) * 1000",
          "legendFormat": "Cursos p99"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"notificaciones\"}[1m])) by (le)) * 1000",
          "legendFormat": "Notificaciones p99"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Requests totales por servicio",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=\"cursos-api\"}[1m])) by (route)",
          "legendFormat": "cursos — {{route}}"
        },
        {
          "expr": "sum(rate(http_requests_total{job=\"notificaciones\"}[1m])) by (route)",
          "legendFormat": "notif — {{route}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 7,
      "type": "gauge",
      "title": "Errores por código HTTP",
      "gridPos": { "x": 0, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "expr": "sum by (status_code) (rate(http_requests_total[5m]))",
        "legendFormat": "HTTP {{status_code}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "max": 100 }
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memoria usada (MB)",
      "gridPos": { "x": 8, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "expr": "process_resident_memory_bytes / 1024 / 1024",
        "legendFormat": "{{job}} — RSS MB"
      }],
      "fieldConfig": {
        "defaults": { "unit": "MiB", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 9,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 6 },
      "targets": [{
        "expr": "process_start_time_seconds{job=\"cursos-api\"}",
        "legendFormat": "cursos-api start"
      }],
      "fieldConfig": {
        "defaults": { "unit": "dateTimeAsIso" }
      }
    }
  ]
}
